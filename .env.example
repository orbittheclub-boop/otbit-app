# Copy to `.env` and fill in. These are public client keys (safe to ship).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_ANON_KEY=eyJ... (legacy anon JWT, used as the apikey header)

# Google native sign-in (iOS OAuth client id)
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
